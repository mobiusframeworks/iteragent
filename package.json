{
  "name": "intertools",
  "version": "1.0.16",
  "description": "Professional console log analysis and IDE integration with AI-powered insights. Completely FREE with all features: terminal monitoring, AI chat orchestrator, production analytics, and more!",
  "main": "packages/intertools/dist/index.js",
  "bin": {
    "intertools": "packages/intertools/dist/index.js"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "pnpm -r dev",
    "install-cli": "cd packages/@intertools/cli && npm install -g .",
    "install-lib": "cd packages/intertools && npm install -g .",
    "start-server": "cd apps/server && npm run dev",
    "start-frontend": "cd intertools-pro-frontend && npm run dev",
    "start-pro": "concurrently \"npm run start-server\" \"npm run start-frontend\"",
    "generate-keys": "cd apps/server && npm run generate-keys",
    "build-extension": "cd browser-extensions/chrome && zip -r ../../intertools-pro-frontend/downloads/intertools-chrome-extension.zip .",
    "example": "cd examples/react-vite && npm install && npm run dev",
    "activate": "npx @intertools/cli activate",
    "status": "npx @intertools/cli status"
  },
  "keywords": [
    "intertools",
    "console",
    "logs",
    "ide",
    "cursor",
    "vscode",
    "analysis",
    "ai",
    "pro",
    "subscription",
    "browser-extension",
    "development",
    "debugging",
    "monitoring"
  ],
  "author": "Alex Horton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luvs2spluj/intertools.git"
  },
  "bugs": {
    "url": "https://github.com/luvs2spluj/intertools/issues"
  },
  "homepage": "https://intertools.pro",
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "intertools": "^1.0.15"
  }
}
