# Railway Environment Variables
NODE_ENV=production
PORT=3001

# Railway will automatically set RAILWAY_STATIC_URL
# RAILWAY_STATIC_URL=https://your-app.railway.app

# Optional: Database URL (if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:port/database

# Optional: Stripe for payments (Pro features)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# Optional: JWT Secret for session management
# JWT_SECRET=your-super-secret-jwt-key

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://yoursite.com,chrome-extension://

# Optional: Log level
LOG_LEVEL=info
