# InterTools Pro License Server Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_monthly_price_id_here

# JWT Configuration
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=intertools-pro
JWT_AUDIENCE=intertools-users

# Rate Limiting
TRIAL_RATE_LIMIT_PER_EMAIL=3
TRIAL_RATE_LIMIT_WINDOW_HOURS=24
API_RATE_LIMIT_PER_MINUTE=100

# Database (optional - for production use Redis or PostgreSQL)
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql://user:pass@localhost:5432/intertools

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/server.log

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5174,chrome-extension://

# Admin Configuration
ADMIN_EMAIL=admin@intertools.com
ADMIN_PASSWORD_HASH=$2b$10$your_bcrypt_hash_here

# Email Configuration (for notifications)
# SENDGRID_API_KEY=your_sendgrid_key
# FROM_EMAIL=noreply@intertools.com
