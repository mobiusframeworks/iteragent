    "@types/node": "^20.10.4",
    "@types/node-fetch": "^2.6.9",
    "@types/inquirer": "^9.0.7",
    "@types/ora": "^3.2.0",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
