{
  "name": "iteragent-cli",
  "version": "1.0.3",
  "description": "Iterative testing agent for Cursor IDE - runs apps, captures logs, tests, and feeds back to Cursor",
  "main": "dist/index.js",
  "bin": {
    "iteragent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "keywords": [
    "cursor",
    "testing",
    "development",
    "automation",
    "playwright",
    "cli"
  ],
  "author": "Alex Horton",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "playwright": "^1.40.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "node-pty": "^1.0.0",
    "ws": "^8.14.2",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/inquirer": "^8.2.6",
    "@types/ws": "^8.5.8",
    "@types/cors": "^2.8.15",
    "typescript": "^5.2.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexhorton/iteragent.git"
  },
  "bugs": {
    "url": "https://github.com/alexhorton/iteragent/issues"
  },
  "homepage": "https://github.com/alexhorton/iteragent#readme"
}
